class KthLargest {
    private int k;
    private int[] minHeap;
    private int size = 0;

    public KthLargest(int k, int[] nums) {
        this.k = k;
        minHeap = new int[k];
        
        for (int n:nums) {
            add(n);
        }
    }

    public int add(int val) {
        if (size < k) {
            insert(minHeap, val);
        }
        else if (val > minHeap[0]) {
            removeSmallest(minHeap);
            insert(minHeap, val);
        }

        return minHeap[0];
    }

    public int[] insert(int[] minHeap, int elem) {
        size++;
        minHeap[size-1] = elem;
        
        int current = size-1;
        while (minHeap[current] < minHeap[(current-1)/2] && current>0) {
            minHeap = swap(minHeap, current, (current-1)/2);
            current = (current-1)/2;
        }

        return minHeap;
    }

    public int removeSmallest(int[] minHeap) {
        if (size == 0){
            System.out.println("Can't remove from empty list");
            return -1; 
        }

        minHeap = swap(minHeap, 0, size-1);
        size--;

        if (size != 0) {
            pushDown(0);
        }

        return minHeap[size];
    }

    public void pushDown(int pos) {
        while (2*pos + 1 < size) {
            int rightChild = pos*2 + 2;
            int leftChild = pos*2 + 1;

            int smallestChild = leftChild;

            if (rightChild < size && minHeap[rightChild] < minHeap[leftChild]) {
                smallestChild = rightChild;
            }

            if (minHeap[pos] <= minHeap[smallestChild] || smallestChild >= size) {
                break;
            }

            minHeap = swap(minHeap, pos, smallestChild);
            pos = smallestChild;
        }
        
    }

    public int[] swap(int[] minHeap, int pos1, int pos2) {
        int tmp = minHeap[pos1];
        minHeap[pos1] = minHeap[pos2];
        minHeap[pos2] = tmp;

        return minHeap;
    }
}

